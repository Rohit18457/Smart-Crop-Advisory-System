# Smart Agriculture Backend — Environment Variables
# ==================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to Git.

FLASK_SECRET_KEY=CHANGE_ME_to_a_random_64_char_hex_string
OPENWEATHER_API_KEY=your-openweathermap-api-key
CROP_PRICE_API_KEY=your-data-gov-in-api-key
GROQ_API_KEY=your-groq-api-key

# Supabase JWT Secret (get from: Supabase Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Rate Limiter (optional — defaults to in-memory)
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0
